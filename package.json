{
  "name": "kabanchik-launcher",
  "version": "1.0.0",
  "description": "KabanchikLauncher - Оптимизированный лаунчер Minecraft",
  "main": "src/main/index.js",
  "author": "KabanchikLauncher Team",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"webpack --watch --config webpack.config.js\" \"wait-on dist/renderer.js && electron . --dev\"",
    "build:renderer": "webpack --config webpack.config.js --mode production",
    "build": "npm run build:renderer && electron-builder --win",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.10.2",
    "msmc": "^4.1.0",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "adm-zip": "^0.5.10",
    "uuid": "^9.0.0",
    "node-stream-zip": "^1.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "style-loader": "^3.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "com.kabanchik.launcher",
    "productName": "KabanchikLauncher",
    "copyright": "Copyright 2024 KabanchikLauncher",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KabanchikLauncher"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  }
}
